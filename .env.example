# ─────────────────────────────────────────────────────────────────────────────
# BMK Rekabet İstihbaratı — Ortam Değişkenleri Şablonu
#
# Kurulum:
#   1) Bu dosyayı `.env` olarak kopyalayın:   cp .env.example .env
#   2) Aşağıdaki değerleri doldurun.
#   3) SECRET_KEY için:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# UYARI: .env dosyası asla commit edilmez. .gitignore tarafından koruma altında.
# ─────────────────────────────────────────────────────────────────────────────

# Flask — ZORUNLU. Boş bırakırsanız uygulama açılmaz.
# Üretim: rastgele 48+ karakter.
SECRET_KEY=

# PostgreSQL — ZORUNLU
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://bmk_user:bmk_pass@localhost:5432/saas_db

# Groq (YZ Danışman) — Kurumsal plan özelliği için zorunlu
GROQ_API_KEY=

# Celery / Redis — Arka plan görev kuyruğu
# Lokal:   redis://localhost:6379/0
# Bulut:   rediss://... (SSL)
CELERY_BROKER_URL=redis://localhost:6379/0

# Onay modu: 'manual' (admin onay verir) | 'auto' (otomatik onay)
APPROVAL_MODE=manual

# Ücretsiz deneme süresi (gün)
FREE_TRIAL_DAYS=14

# ── Observability (Faz 9A) ────────────────────────────────────────────────
# Sentry DSN — boş bırakılırsa Sentry aktif olmaz (geliştirmede güvenli).
# Üretimde: https://sentry.io → yeni proje → DSN'yi kopyala.
SENTRY_DSN=
# 'production' | 'staging' | 'development'
SENTRY_ENVIRONMENT=development
# Performance trace örnekleme oranı (0.0 – 1.0). 0.1 = istek başına %10.
SENTRY_TRACES_RATE=0.1
