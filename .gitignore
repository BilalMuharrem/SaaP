__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
*.manifest
*.spec

# Sanal ortam
.venv/
venv/
env/
ENV/

# Veritabanı (lokal)
*.db
*.sqlite
*.sqlite3
instance/
celerybeat-schedule*

# IDE / Editör
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.pydevproject

# İşletim sistemi
.DS_Store
Thumbs.db
desktop.ini

# Loglar
*.log
logs/

# Yedekler (Faz 9B)
backups/

